---
import Section from './Section.astro';

const steps = [
  ['Fuel Sold', 'Meter reading closes the sale.'],
  ['Inventory Updated', 'Tank stock and variance move automatically.'],
  ['Journal Created', 'Money and ledger entries are posted.'],
  ['Dashboard Updated', 'Owner and manager see live position.'],
  ['Owner Notified', 'Exceptions surface without phone calls.'],
];
---

<Section id="connected" title="Everything connects automatically." lead="PumpOS turns your event-driven architecture into a business advantage: every operational action updates the records that depend on it.">
  <div class="rounded-2xl border border-[var(--color-border-soft)] bg-white p-6 sm:p-8">
    <div class="grid gap-4 lg:grid-cols-5">
      {steps.map(([title, body], index) => (
        <div class="relative rounded-xl bg-[var(--color-canvas)] p-5">
          <span class="font-mono text-sm font-semibold text-[var(--color-brand)]">{String(index + 1).padStart(2, '0')}</span>
          <h3 class="mt-3 text-lg font-semibold text-[var(--color-ink)]">{title}</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--color-ink-muted)]">{body}</p>
        </div>
      ))}
    </div>
  </div>
</Section>
