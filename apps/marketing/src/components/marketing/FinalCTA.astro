---
import { CONSOLE_URL } from '../../config.ts';
---

<section class="mx-auto max-w-6xl px-6 pb-24 pt-8">
  <div class="rounded-2xl bg-[var(--color-brand)] px-6 py-14 text-center text-white sm:px-10">
    <h2 class="mx-auto max-w-3xl text-balance text-3xl font-semibold tracking-[-0.02em] sm:text-5xl">See PumpOS in action before you trust it with your station.</h2>
    <p class="mx-auto mt-4 max-w-2xl text-pretty text-white/85">A live demo is the fastest way to test the operating model: shift close, variance, credit, stock, DSSR and owner visibility in one flow.</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="mailto:hello@pumpos.app?subject=Request%20PumpOS%20demo" class="w-full rounded-lg bg-white px-6 py-3 font-semibold text-[var(--color-brand-dark)] transition hover:bg-white/90 sm:w-auto">Schedule a Live Demo</a>
      <a href={CONSOLE_URL} class="w-full rounded-lg border border-white/40 px-6 py-3 font-semibold text-white transition hover:bg-white/10 sm:w-auto">Open Console</a>
    </div>
  </div>
</section>
