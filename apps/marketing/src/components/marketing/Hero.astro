---
import { CONSOLE_URL } from '../../config.ts';
import ProductFrame from './ProductFrame.astro';
---

<section class="mx-auto grid max-w-6xl items-center gap-10 px-6 pb-16 pt-16 sm:pb-20 sm:pt-24 lg:grid-cols-[0.95fr_1.05fr]">
  <div>
    <p class="inline-flex rounded-full border border-[var(--color-border-soft)] bg-white px-3 py-1 text-sm font-medium text-[var(--color-ink-muted)]">
      Built for Indian fuel stations
    </p>
    <h1 class="mt-6 text-balance text-5xl font-semibold leading-[1.02] tracking-[-0.03em] text-[var(--color-ink)] sm:text-6xl lg:text-7xl">
      The Operating System for Modern Fuel Retail.
    </h1>
    <p class="mt-6 max-w-2xl text-pretty text-lg leading-8 text-[var(--color-ink-muted)]">
      Run your entire fuel station — from forecourt operations and shift reconciliation to inventory, accounting, and business insights — in one connected platform.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a href="mailto:hello@pumpos.app?subject=Request%20PumpOS%20demo" class="inline-flex justify-center rounded-lg bg-[var(--color-brand)] px-5 py-3 font-semibold text-white transition hover:bg-[var(--color-brand-dark)]">
        Request Demo
      </a>
      <a href="#product-tour" class="inline-flex justify-center rounded-lg border border-[var(--color-border-soft)] bg-white px-5 py-3 font-semibold text-[var(--color-ink)] transition hover:border-[var(--color-brand)]">
        Watch Product Tour
      </a>
    </div>
    <div class="mt-8 flex flex-wrap gap-2 text-sm text-[var(--color-ink-muted)]">
      {['Works Offline', 'Multi Station', 'Cloud Sync', 'GST Ready', 'Real-Time Insights'].map((badge) => (
        <span class="rounded-full border border-[var(--color-border-soft)] bg-white px-3 py-1">{badge}</span>
      ))}
    </div>
  </div>

  <div class="relative">
    <div class="absolute -inset-4 -z-10 rounded-[24px] bg-[#DDEBE5]"></div>
    <ProductFrame
      title="Owner dashboard"
      subtitle="Kannur Station · live business day"
      metrics={[
        { label: 'Today sales', value: '₹3,36,161', sub: 'fuel + lubricant' },
        { label: 'Net volume', value: '3,318 L', sub: 'meter-derived' },
        { label: 'Cash position', value: 'Matched', sub: 'no variance' },
      ]}
      rows={[
        { name: 'Morning Shift', meta: 'Open · 6 nozzles · 2 operators', value: '₹1,42,880', status: 'ok' },
        { name: 'Petrol tank', meta: '11,240 L available · 2.1% variance watch', value: '62%', status: 'info' },
        { name: 'Fleet receivables', meta: '4 accounts crossed terms', value: '₹38,500', status: 'warn' },
      ]}
    />
    <div class="mt-4 text-center text-xs text-[var(--color-ink-muted)]">Representative PumpOS product view. Replace with live captures before launch.</div>
  </div>
</section>
