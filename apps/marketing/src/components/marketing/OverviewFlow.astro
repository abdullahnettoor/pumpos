---
import Section from './Section.astro';

const flow = ['Operations', 'Inventory', 'Accounting', 'Analytics', 'Business Decisions'];
---

<Section
  id="platform"
  title="Built around how fuel stations actually work."
  lead="PumpOS connects the daily operating flow instead of forcing your station into disconnected modules and duplicate entry."
>
  <div class="border-y border-[var(--color-border-strong)] bg-white py-1">
    <div class="grid gap-px bg-[var(--color-border-soft)] md:grid-cols-5 md:items-stretch">
      {flow.map((item, index) => (
        <>
          <div class="relative bg-white p-5 text-left sm:p-6">
            <span class="font-mono text-xs font-semibold text-[var(--color-brand)]">{String(index + 1).padStart(2, '0')}</span>
            <p class="mt-4 font-semibold text-[var(--color-ink)]">{item}</p>
            <p class="mt-1 text-xs leading-5 text-[var(--color-ink-muted)]">
              {index === 0 ? 'Shift, nozzle, cash' : index === 1 ? 'Stock and variance' : index === 2 ? 'Ledger and journals' : index === 3 ? 'DSSR and KPIs' : 'Owner control'}
            </p>
          </div>
        </>
      ))}
    </div>
    <p class="mx-auto max-w-3xl px-6 py-7 text-center text-sm leading-6 text-[var(--color-ink-muted)]">
      One workflow. One source of truth. Every sale, collection, purchase, expense, and variance is anchored to the right business day and becomes part of the same auditable record.
    </p>
  </div>
</Section>
