---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — PumpOS" path="/404">
  <section class="mx-auto flex max-w-xl flex-col items-center px-6 py-28 text-center">
    <p class="font-mono text-sm" style="color: var(--color-brand)">404</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">Page not found</h1>
    <p class="mt-3 text-[var(--color-ink-muted)]">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a
      href="/"
      class="mt-8 rounded-lg bg-[var(--color-brand)] px-6 py-3 font-medium text-white transition hover:bg-[var(--color-brand-dark)]"
      >Back to home</a
    >
  </section>
</BaseLayout>
