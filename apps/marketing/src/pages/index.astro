---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/marketing/Hero.astro';
import PainSection from '../components/marketing/PainSection.astro';
import OverviewFlow from '../components/marketing/OverviewFlow.astro';
import ProductTour from '../components/marketing/ProductTour.astro';
import ConnectedWorkflow from '../components/marketing/ConnectedWorkflow.astro';
import Capabilities from '../components/marketing/Capabilities.astro';
import Comparison from '../components/marketing/Comparison.astro';
import Audience from '../components/marketing/Audience.astro';
import PlatformAdvantages from '../components/marketing/PlatformAdvantages.astro';
import ProofStory from '../components/marketing/ProofStory.astro';
import FAQ from '../components/marketing/FAQ.astro';
import FinalCTA from '../components/marketing/FinalCTA.astro';
---

<BaseLayout
  title="PumpOS — The Operating System for Modern Fuel Retail"
  description="Run forecourt operations, shift reconciliation, inventory, accounting and owner insights in one connected platform for fuel stations."
>
  <Hero />
  <PainSection />
  <OverviewFlow />
  <ProductTour />
  <ConnectedWorkflow />
  <Capabilities />
  <Comparison />
  <Audience />
  <PlatformAdvantages />
  <ProofStory />
  <FAQ />
  <FinalCTA />
</BaseLayout>
