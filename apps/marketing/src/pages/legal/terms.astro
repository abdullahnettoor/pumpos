---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service — PumpOS" path="/legal/terms">
  <article class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-3xl font-bold tracking-tight">Terms of Service</h1>
    <p class="mt-2 text-sm text-[var(--color-ink-muted)]">Last updated: {new Date().getFullYear()}</p>
    <div class="mt-8 space-y-4 text-[var(--color-ink-muted)] leading-relaxed">
      <p>
        This is a placeholder terms of service for PumpOS. Final legal copy will
        be published before general availability.
      </p>
      <p>
        By using PumpOS you agree to operate within the intended scope of fuel
        station management and to keep your account credentials secure.
      </p>
    </div>
  </article>
</BaseLayout>
