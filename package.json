{
  "name": "pumpos-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "PumpOS Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:api:local": "npm run dev:local --workspace=apps/api",
    "dev:api:remote": "npm run dev:remote --workspace=apps/api",
    "deploy:api": "npm run deploy --workspace=apps/api",
    "deploy:web": "npm run deploy --workspace=apps/web",
    "build": "tsc -b && npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace=apps/api",
    "build:ui-web": "npm run build --workspace=packages/ui && npm run build --workspace=apps/web",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "typescript": "^5.4.5"
  }
}
