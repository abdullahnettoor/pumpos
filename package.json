{
  "name": "pumpos-monorepo",
  "private": true,
  "version": "1.0.1",
  "description": "PumpOS Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:console": "npm run dev --workspace=apps/console",
    "dev:marketing": "npm run dev --workspace=apps/marketing",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:api:local": "npm run dev:local --workspace=apps/api",
    "dev:api:remote": "npm run dev:remote --workspace=apps/api",
    "deploy:api": "npm run deploy --workspace=apps/api",
    "deploy:console": "npm run deploy --workspace=apps/console",
    "deploy:marketing": "npm run deploy --workspace=apps/marketing",
    "deploy:mobile": "npm run deploy --workspace=apps/mobile",
    "build": "tsc -b && npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace=apps/api",
    "build:ui-console": "npm run build --workspace=packages/ui && npm run build --workspace=apps/console",
    "build:marketing": "npm run build --workspace=apps/marketing",
    "build:ui-mobile": "npm run build --workspace=packages/ui && npm run build --workspace=apps/mobile",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "fonts": "node scripts/download-fonts.mjs",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "typescript": "^5.4.5"
  }
}
