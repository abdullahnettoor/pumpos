{
  "name": "@pump/db",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "db:generate": "drizzle-kit generate && mkdir -p ../../supabase/migrations && cp migrations/*.sql ../../supabase/migrations/ 2>/dev/null || true",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node seed.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.31.10",
    "pg": "^8.11.5",
    "typescript": "^5.4.5"
  }
}
